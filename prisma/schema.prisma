// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("POSTGRES_PRISMA_URL")
  directUrl    = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  ORDERED
  ARRIVED
  ARCHIVED
}

model FabricOrder {
  id          String      @id @default(cuid())
  orderNumber String
  fabricName  String
  meters      Float
  model       String?
  modules     String?
  status      OrderStatus @default(PENDING)
  comment     String?
  crmId       Int?
  crmTitle    String?
  crmComment  String?
  funnelId    Int?
  orderedAt   DateTime?
  arrivedAt   DateTime?
  archivedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([crmId])
}

/// Сырые сделки из KeepinCRM (воронки 1 и 8), которые ещё не превратили в FabricOrder.
/// processedAt — пользователь перенёс в "Нужно заказать" (создан FabricOrder).
/// dismissedAt — пользователь вручную скрыл (мусорная карточка, не превращать).
/// Обе пометки исключают сделку из выдачи и из повторного импорта.
model UnsortedDeal {
  id           String    @id @default(cuid())
  crmId        Int       @unique
  crmTitle     String
  crmComment   String?
  funnelId     Int
  funnelTitle  String?
  stageId      Int?
  stageName    String?
  fabric       String?
  model        String?
  modules      String?
  orderNumber  String?
  processedAt  DateTime?
  dismissedAt  DateTime?
  importedAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([processedAt, dismissedAt])
  @@index([crmId])
}